DISCORD_TOKEN=your_bot_token_here

# Database backend: "sqlite" (default) or "postgresql"
DB_BACKEND=postgresql

# PostgreSQL (Docker Compose 기본값)
DATABASE_URL=postgresql://logbot:your_postgres_password_here@postgres:5432/logbot
POSTGRES_PASSWORD=your_postgres_password_here

# SQLite settings (DB_BACKEND=sqlite 일 때만 사용)
# DB_PATH=./data/logbot.db

# ── 웹 서비스 (Discord OAuth2) ──
# Discord Developer Portal → OAuth2 에서 발급
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# Redirect URI는 Discord Developer Portal의 OAuth2 → Redirects에 동일하게 등록 필요
DISCORD_REDIRECT_URI=http://your-server-ip:8080/auth/callback

# JWT 서명 키 (랜덤 문자열, 예: openssl rand -hex 32) ← 필수, 미설정 시 서버 시작 불가
JWT_SECRET=your_jwt_secret_here

# ── MCP 서버 ──
# 외부에서 접근 가능한 서버 기본 URL (MCP OAuth redirect URI 생성에 사용)
BASE_URL=https://your-domain.com
# Discord Developer Portal → OAuth2 → Redirects에 아래 URI 등록 필요:
#   {BASE_URL}/oauth/discord_callback
#   {BASE_URL}/auth/callback

# MCP OAuth: localhost 외 허용할 redirect_uri 목록 (쉼표 구분, 선택사항)
# MCP_ALLOWED_REDIRECT_URIS=https://your-app.example.com/callback

# MCP OAuth: 허용할 client_id 목록 (쉼표 구분) ← 미설정 시 모든 요청 거부
# Claude Desktop 등 클라이언트의 client_id를 등록
# MCP_CLIENT_IDS=claude-desktop,my-custom-client
